@startuml
skinparam packageStyle rectangle

package "template" {
  class Launcher
  class Config
  class Sketch
  class MainInputLayer
  class Log
}

package "cpz-mvvm-processing-controls" {
  interface Control
  class Button
  class Label
  class InputManager
  class DefaultInputLayer
  class PointerEvent
  class KeyboardEvent
}

class "processing.core.PApplet" as PApplet

Sketch --|> PApplet
Sketch --> Config
Sketch --> InputManager
Sketch --> MainInputLayer
Sketch --> Button
Sketch --> Label
Sketch ..> PointerEvent

MainInputLayer --|> DefaultInputLayer
MainInputLayer ..> PointerEvent
MainInputLayer ..> KeyboardEvent

Button ..|> Control
Label ..|> Control

Launcher ..> Sketch
Launcher ..> Log
Launcher ..> PApplet
@enduml
