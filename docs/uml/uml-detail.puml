@startuml
skinparam classAttributeIconSize 0

package "com.cpz.processing.template.main" {
  class Launcher {
    + main(args: String[]): void
  }

  class Sketch {
    - inputManager: InputManager
    - button: Button
    - label: Label
    - clickCount: int
    --
    + settings(): void
    + setup(): void
    + draw(): void
    + mouseMoved(): void
    + mouseDragged(): void
    + mousePressed(): void
    + mouseReleased(): void
    --
    - btnTestClicked(): void
  }
}

package "com.cpz.processing.template.config" {
  class Config {
    + settings(sk: Sketch): void
    + setup(sk: Sketch): void
  }
}

package "com.cpz.processing.template.input" {
  class MainInputLayer {
    - pointerTargets: List<PointerTarget>
    - keyboardTargets: List<KeyboardTarget>
    --
    + MainInputLayer(priority: int)
    + addPointerTarget(target: PointerTarget): MainInputLayer
    + addKeyboardTarget(target: KeyboardTarget): MainInputLayer
    + handlePointerEvent(event: PointerEvent): boolean
    + handleKeyboardEvent(event: KeyboardEvent): boolean
  }

  interface PointerTarget {
    + handlePointerEvent(event: PointerEvent): void
  }

  interface KeyboardTarget {
    + handleKeyboardEvent(event: KeyboardEvent): void
  }
}

package "cpz-mvvm-processing-controls" {
  interface Control
  class Button {
    + handlePointerEvent(event: PointerEvent): void
    + setClickListener(listener): void
  }
  class Label {
    + setText(text: String): void
  }
  class InputManager {
    + registerLayer(layer: InputLayer): void
    + dispatchPointer(event: PointerEvent): void
    + dispatchKeyboard(event: KeyboardEvent): void
  }
  class DefaultInputLayer
  class PointerEvent
  class KeyboardEvent
}

class "processing.core.PApplet" as PApplet

Sketch --|> PApplet
MainInputLayer --|> DefaultInputLayer
Button ..|> Control
Label ..|> Control

Launcher ..> Sketch
Sketch ..> Config
Sketch --> InputManager
Sketch --> MainInputLayer
Sketch --> Button
Sketch --> Label
Sketch ..> PointerEvent

MainInputLayer o--> PointerTarget
MainInputLayer o--> KeyboardTarget
MainInputLayer ..> PointerEvent
MainInputLayer ..> KeyboardEvent

note right of MainInputLayer
Template-owned routing layer.
The sketch registers public facade
input methods explicitly.
end note

note bottom of Sketch
Behavior stays in the sketch:
button click increments local state
and updates the label facade.
end note
@enduml
